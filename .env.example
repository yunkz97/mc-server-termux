VERSION=1.0.0
FIRST_RUN=true
SERVER_JAR=server.jar
JAVA_RAM=1G
USE_AIKAR_FLAGS=true
SERVER_PORT=25565
PLAYIT_ENABLED=true
PLAYIT_AUTO_RECONNECT=true
PLAYIT_HEALTH_CHECK_INTERVAL=30
PLAYIT_CLAIM_URL=
PLAYIT_TUNNEL_ADDRESS=
FILEBROWSER_ENABLED=true
FILEBROWSER_PORT=8080
FILEBROWSER_USER=admin
FILEBROWSER_PASSWORD=
BATTERY_MONITOR_ENABLED=true
BATTERY_CHECK_INTERVAL=60
BATTERY_ALERT_20=true
BATTERY_ALERT_10=true
BATTERY_ALERT_5=true
LOG_LEVEL=INFO
LOG_ROTATION_SIZE=10M
LOG_ROTATION_COUNT=5
AUTO_BACKUP=false
BACKUP_INTERVAL=24h
SERVER_DIR=$HOME/mc-server-termux/server
DATA_DIR=$HOME/mc-server-termux/data
BIN_DIR=$HOME/mc-server-termux/bin
LOG_DIR=$HOME/mc-server-termux/logs
RUN_DIR=$HOME/mc-server-termux/run
BACKUP_DIR=$HOME/mc-server-termux/backups
